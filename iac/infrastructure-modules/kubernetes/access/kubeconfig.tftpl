apiVersion: v1
kind: Config
clusters:
- name: ${cluster_name}
  cluster:
    certificate-authority-data: ${cluster_ca_data}
    server: ${server}
contexts:
- name: default-context
  context:
    cluster: ${cluster_name}
    namespace: default
    user: ${service_account}
current-context: default-context
users:
- name: ${service_account}
  user:
    token: ${token}